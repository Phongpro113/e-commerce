# =============================================================================
# ENVIRONMENT VARIABLES — sao chép file này thành .env rồi điền giá trị thật
# cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------

# Mật khẩu root MySQL (dùng nội bộ Docker, không expose ra ngoài)
MYSQL_ROOT_PASSWORD=change_me_root_password

# Tên database WordPress
MYSQL_DATABASE=wordpress

# Tài khoản MySQL dành riêng cho WordPress
MYSQL_USER=wp_user
MYSQL_PASSWORD=change_me_db_password

# -----------------------------------------------------------------------------
# WORDPRESS
# -----------------------------------------------------------------------------

# Tiền tố bảng trong database (đổi khỏi "wp_" mặc định để tăng bảo mật)
WORDPRESS_TABLE_PREFIX=wc_

# URL website (không có dấu / ở cuối)
# Local:      http://localhost:8080
# Production: https://yourdomain.com
WORDPRESS_SITE_URL=http://localhost:8080

# Thông tin tài khoản admin WordPress
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=change_me_admin_password
WP_ADMIN_EMAIL=your@email.com

# Tiêu đề website
WP_SITE_TITLE=Shop Bán Hàng

# -----------------------------------------------------------------------------
# PORTS (chỉnh nếu port bị xung đột)
# -----------------------------------------------------------------------------

# Port truy cập website
WP_PORT=8080

# Port truy cập phpMyAdmin
PMA_PORT=8081

# -----------------------------------------------------------------------------
# PHPMYADMIN (production: đặt là "false" hoặc xoá service này)
# -----------------------------------------------------------------------------
PMA_ENABLED=true
